# Database
DATABASE_URL=sqlite:///./data/fipe_hunter.db
# Prod: postgresql+psycopg2://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# Frontend URL (prod only — added to CORS allow list)
# FRONTEND_URL=https://fipe-hunter.vercel.app

# FIPE API
FIPE_API_URL=https://parallelum.com.br/fipe/api/v1

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Scraping
SCRAPE_SCHEDULE_HOURS=1  # Scrape every N hours
REQUEST_DELAY_MIN_SECONDS=1
REQUEST_DELAY_MAX_SECONDS=3

# Admin Auth
ADMIN_USERNAME=admin
# Generate hash: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=change-me-in-production
ADMIN_JWT_EXPIRE_MIN=480

# Logging
LOG_LEVEL=INFO
