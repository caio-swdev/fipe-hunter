@startuml

left to right direction

actor ScoringOrchestrator as scorer
actor CarWizardSystem as carwizard

rectangle "CarWizard Integration" {
  scorer --> (Send Opportunity to CarWizard)

  (Send Opportunity to CarWizard) --> (Prepare Payload)
  (Prepare Payload) --> (Authenticate)
  (Authenticate) --> (Send Request)

  (Send Request) --> (Handle Response)
  (Handle Response) --> (Store CarWizard ID)

  (Send Request) ..> (Retry on Failure) : <<extend>>
  (Store CarWizard ID) --> (Link to Opportunity)

  carwizard -.-> |status update| (Receive Status Update)
  (Receive Status Update) --> (Update Opportunity)
  (Update Opportunity) --> (Log Sync Event)
}

note right of (Prepare Payload)
  Include: brand, model, year,
  mileage, prices, discount, score
end note

note right of (Store CarWizard ID)
  Track bidirectional relationship
  Enable future status updates
end note

@enduml
