@startuml

participant ScoringOrchestrator
participant CarWizardService
participant CarWizardAPI
participant Database

ScoringOrchestrator -> CarWizardService: send_opportunity(opportunity)
activate CarWizardService

CarWizardService -> CarWizardService: check_score_threshold()
alt score >= 80
  CarWizardService -> CarWizardService: prepare_payload(opportunity)
  return payload = {brand, model, year, mileage, listing_price, fipe_price, discount_pct, score, url, timestamp}

  CarWizardService -> CarWizardService: authenticate()
  return auth_headers = {Authorization: "Bearer ..."}

  CarWizardService -> CarWizardAPI: POST /api/opportunities (payload, headers)
  activate CarWizardAPI

  alt Success (HTTP 200)
    CarWizardAPI --> CarWizardService: {ok: true, carwizard_id: "CW123456"}
    deactivate CarWizardAPI

    CarWizardService -> Database: UPDATE opportunities SET carwizard_id='CW123456'
    Database --> CarWizardService: ok

    CarWizardService --> ScoringOrchestrator: {status: 'synced', carwizard_id: 'CW123456'}
    note over CarWizardService
      Opportunity linked to CarWizard
    end note

  else Timeout (> 20 seconds)
    CarWizardAPI -x CarWizardService: timeout
    CarWizardService -> CarWizardService: retry_once()
    alt Retry Succeeds
      CarWizardAPI --> CarWizardService: {ok: true, carwizard_id: "CW123456"}
      CarWizardService -> Database: UPDATE opportunities SET carwizard_id='CW123456'
      Database --> CarWizardService: ok
    else Retry Fails
      CarWizardService -> Database: INSERT opportunity_logs (action: 'carwizard_sync_failed')
      Database --> CarWizardService: ok
      CarWizardService --> ScoringOrchestrator: {status: 'failed', reason: 'timeout'}
    end

  else API Error (HTTP 5xx)
    CarWizardAPI --> CarWizardService: {ok: false, error: 'internal_error'}
    deactivate CarWizardAPI

    CarWizardService -> CarWizardService: exponential_backoff(attempt)
    alt retry_count < 3
      CarWizardService -> CarWizardAPI: retry POST /api/opportunities
      note over CarWizardService
        Retry with backoff: 30s, 60s, 120s
      end note
    else All retries exhausted
      CarWizardService -> Database: INSERT opportunity_logs (action: 'carwizard_failed', details: error_message)
      Database --> CarWizardService: ok
      CarWizardService --> ScoringOrchestrator: {status: 'failed', reason: 'max_retries'}
    end

  else Vehicle Not Found (HTTP 400/422)
    CarWizardAPI --> CarWizardService: {ok: false, error: 'vehicle_not_found'}
    deactivate CarWizardAPI

    CarWizardService -> Database: INSERT opportunity_logs (action: 'carwizard_unrecognized_vehicle')
    Database --> CarWizardService: ok

    CarWizardService --> ScoringOrchestrator: {status: 'failed', reason: 'vehicle_not_found'}
    note over CarWizardService
      Log error, do not retry
      Mark for manual review
    end note
  end

else score < 80
  CarWizardService --> ScoringOrchestrator: {status: 'skipped', reason: 'score_below_threshold'}
  note over CarWizardService
    Score too low - don't send to CarWizard
  end note
end

deactivate CarWizardService

@enduml
