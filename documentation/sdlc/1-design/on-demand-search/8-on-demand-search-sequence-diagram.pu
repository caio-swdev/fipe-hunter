@startuml

title On-Demand Vehicle Search - Sequence Diagram

participant User as user
participant Frontend as frontend
participant APIRouter as api_router
participant OnDemandOrchestrator as orchestrator
participant QueryValidator as validator
participant FIPEClientService as fipe_service
participant PriceCacheRepo as cache_repo
participant OLXScraperClient as olx_scraper
participant ListingValidator as listing_validator
participant PriceComparisonService as price_comp
participant ScoringOrchestrator as scoring_oracle
participant OpportunityRepository as opp_repo
participant ListingRepository as listing_repo
participant VehicleRepository as vehicle_repo
participant GoogleSheetsService as sheets_service
participant TelegramBotService as telegram_service
participant CarWizardService as carwizard_service
participant MessageQueue as msg_queue
participant Database as db

== Search Initiation ==
user -> frontend: Enters "Honda", "Civic", "2020"\nClicks "Search Now"
note right of user
  Input validation on frontend:
  - Brand required
  - Model required
  - Year must be integer 1950-now
end note

frontend -> api_router: POST /api/search/vehicle\n{brand, model, year}
api_router -> orchestrator: execute(brand="Honda", model="Civic", year=2020)

note right of orchestrator
  OnDemandSearchOrchestrator
  coordinates the entire flow
end note

api_router --> frontend: 200 OK\n{status: "processing", search_id, est_time: 25s}
frontend --> user: Display "Loading..." indicator

== Input Validation ==
orchestrator -> validator: validate_and_parse(brand, model, year)
validator -> validator: Validate inputs
note right of validator
  - brand required, non-empty
  - model required, non-empty
  - year integer 1950-now (optional)
end note

validator -> validator: Normalize names\n"VW" -> "Volkswagen"
validator --> orchestrator: {brand, model, year}

== FIPE Price Lookup ==
orchestrator -> cache_repo: get_cached_price(brand, model, year)
note right of cache_repo
  Check if FIPE price cached
  within last 24 hours
end note

alt Cache Hit
  cache_repo --> orchestrator: fipe_price = 60000
  note right of orchestrator
    Use cached price
    No API call needed
  end note
else Cache Miss
  orchestrator -> fipe_service: get_price(brand="Honda", model="Civic", year=2020)
  fipe_service -> fipe_service: Build FIPE API request

  note right of fipe_service
    Query: parallelum.com.br/api/...
    Timeout: 10 seconds
    Retry: exponential backoff on 429
  end note

  fipe_service --> orchestrator: fipe_price = 60000
  orchestrator -> cache_repo: set(key, price, ttl=24h)
  note right of cache_repo
    Cache for 24 hours
  end note
  cache_repo --> orchestrator: cached
end

== OLX Scraping (Concurrent with Display) ==
frontend -> user: Update: "Searching OLX..." (5-10 sec elapsed)

orchestrator -> olx_scraper: scrape_search_query(\n  search="Honda Civic 2020")

note right of olx_scraper
  OLXScraperClient
  - Build URL: olx.com.br/autos?q=...
  - Rotate user-agent headers
  - Apply 1-3 second delays between requests
  - Parse HTML to extract listings
end note

olx_scraper -> olx_scraper: Fetch OLX page
note over olx_scraper
  GET https://www.olx.com.br/autos?q=Honda+Civic+2020
  User-Agent: Mozilla/5.0... (rotated)
  Delay: 2 seconds
end note

olx_scraper -> olx_scraper: Parse HTML\nExtract listings

note right of olx_scraper
  For each <li class="listing">:
  - Extract vehicle: brand, model, year
  - Extract price: R$ amount
  - Extract mileage, condition
  - Extract seller, rating
  - Extract url, description
  - created_at timestamp
end note

olx_scraper --> orchestrator: [{listing1}, {listing2}, ..., {listing5}]

note right of orchestrator
  5 listings extracted from OLX
  (15-25 seconds elapsed)
end note

== Listing Validation ==
orchestrator -> listing_validator: validate_listings(listings)

note right of listing_validator
  Validate each listing:
  - Price > 0
  - URL is valid HTTPS
  - Brand/model match query (fuzzy)
  - Year matches (if specified)
end note

listing_validator --> orchestrator: [validated_listings]

== Deduplication ==
orchestrator -> listing_repo: find_by_url(url1)
note right of listing_repo
  Check if listing already in database
  from previous bulk scrape
end note

alt URL exists in DB
  listing_repo --> orchestrator: {existing_listing}
  orchestrator -> opp_repo: find_by_listing(url1)

  alt Opportunity exists
    opp_repo --> orchestrator: {existing_opp, status="archived"}
    orchestrator -> orchestrator: Mark as duplicate\nUpdate status to "new"
  end
else URL new
  orchestrator -> orchestrator: Add to dedup list
end

== Price Comparison ==
frontend -> user: Update: "Comparing prices..." (25-30 sec elapsed)

orchestrator -> price_comp: execute(listings, fipe_price=60000)

note right of price_comp
  For each listing:
  - discount_pct = (FIPE - listing) / FIPE * 100
  - discount_amount = FIPE - listing (in BRL)
  - Validate: 20% <= discount <= 50%
  - Filter out if <20% or >50%
end note

price_comp -> price_comp: Calculate discounts
note over price_comp
  Listing 1: 45,000 -> discount = 25%
  Listing 2: 48,000 -> discount = 20%
  Listing 3: 50,000 -> discount = 17% (filtered)
  Listing 4: 40,000 -> discount = 33%
  Listing 5: 30,000 -> discount = 50%
end note

price_comp --> orchestrator: [discounted_listings]

== Scoring ==
orchestrator -> scoring_oracle: score_opportunity(\n  listings, fipe_price)

note right of scoring_oracle
  For each listing calculate:
  - discount_score (40% weight)
  - condition_score (30% weight)
  - demand_score (20% weight)
  - recency_score (10% weight)
  - Final = weighted average (0-100)
end note

scoring_oracle -> scoring_oracle: Calculate scores
note over scoring_oracle
  Listing 1: discount=25%, cond=75%, \n    demand=80%, recency=90% -> Score=81
  Listing 2: discount=20%, cond=100%, \n    demand=85%, recency=95% -> Score=82
  Listing 4: discount=33%, cond=85%, \n    demand=80%, recency=88% -> Score=83
  Listing 5: discount=50%, cond=60%, \n    demand=80%, recency=70% -> Score=76
end note

scoring_oracle --> orchestrator: [scored_opportunities]
note right of orchestrator
  Sort by score descending:
  Listing 4 (83), Listing 2 (82),
  Listing 1 (81), Listing 5 (76)
end note

== Database Persistence ==
orchestrator -> vehicle_repo: save_or_get(vehicle)
vehicle_repo --> orchestrator: vehicle_id

orchestrator -> listing_repo: save(listing)
listing_repo --> orchestrator: listing_id

orchestrator -> opp_repo: save(opportunity)
note right of opp_repo
  INSERT OR UPDATE opportunities
  - listing_id
  - fipe_price
  - discount_pct, discount_amount
  - score
  - status = "new"
  - source = "on_demand_search"
  - created_at = now()
end note

opp_repo -> db: INSERT/UPDATE
db --> opp_repo: saved
opp_repo --> orchestrator: opportunity_id

note right of orchestrator
  4 opportunities saved
  (30-35 seconds elapsed)
end note

== Display Results to User ==
frontend -> user: Update: "Results ready!"
frontend -> user: Display 4 opportunities in table
note right of user
  Opportunity Browser shows:
  | Score | Brand | Model | Year | \
  | Listing Price | FIPE Price | Discount | URL |

  Sorted by score descending
end note

== Downstream Actions (Asynchronous) ==

par Google Sheets Logging
  orchestrator -> sheets_service: append_opportunity(opp1)
  sheets_service -> sheets_service: Format row\n{brand, model, price, fipe, discount, score, url}
  sheets_service -> msg_queue: queue_append(row)
  msg_queue --> sheets_service: queued
  note right of msg_queue
    Google Sheets append queued
    Scheduler will process (non-blocking)
  end note
  sheets_service --> orchestrator: queued
end

par Telegram Alerts (Score > 75)
  note right of orchestrator
    Opportunities 1,2,4 score > 75
    Opportunity 5 score = 76 (borderline, send)
    All 4 get alerts
  end note

  orchestrator -> telegram_service: send_alert(opp1, score=83)
  orchestrator -> telegram_service: send_alert(opp2, score=82)
  orchestrator -> telegram_service: send_alert(opp4, score=83)
  orchestrator -> telegram_service: send_alert(opp5, score=76)

  note right of telegram_service
    For each opportunity:
    - Format message: "🚗 Honda Civic 2020..."
    - Queue for rate limiting
  end note

  telegram_service -> msg_queue: queue_message(msg, chat_id)
  msg_queue --> telegram_service: queued

  note right of msg_queue
    Scheduler processes queue
    respecting rate limit (30 msg/sec)
  end note

  telegram_service --> orchestrator: queued
end

par CarWizard Sync (Score > 80)
  note right of orchestrator
    Opportunities 1,2,4 score > 80
    Sync to CarWizard
  end note

  orchestrator -> carwizard_service: sync_opportunity(opp1)
  orchestrator -> carwizard_service: sync_opportunity(opp2)
  orchestrator -> carwizard_service: sync_opportunity(opp4)

  note right of carwizard_service
    Prepare payload:
    {vehicle, listing, opportunity, score, source}
    Send to CarWizard API
  end note

  carwizard_service -> carwizard_service: Prepare payload
  carwizard_service -> msg_queue: queue_sync(payload)
  msg_queue --> carwizard_service: queued

  carwizard_service --> orchestrator: queued

  note right of msg_queue
    Scheduler processes queue
    CarWizard updates stored
  end note
end

== Completion ==
orchestrator --> api_router: {status: "completed", count: 4}
api_router --> frontend: Results available
frontend --> user: Refresh opportunity browser\nShow new results

note over user, orchestrator
  Total time: 30-40 seconds
  - FIPE lookup: 2-5 seconds (or <100ms cached)
  - OLX scraping: 15-25 seconds
  - Processing: 5-10 seconds
  - Downstream: Queued (non-blocking)
end note

== Error Scenario Example ==

alt FIPE API Error
  orchestrator -> fipe_service: get_price(...)
  fipe_service -> fipe_service: API timeout or 5xx
  fipe_service --> orchestrator: ERROR
  orchestrator -> orchestrator: Handle error\nLog failure
  orchestrator --> api_router: {status: "error", message: "FIPE lookup failed"}
  api_router --> frontend: 500 FIPE Error
  frontend --> user: Display error\n"Vehicle not found"\n[Retry]
end

alt OLX Scraping Error
  olx_scraper -> olx_scraper: Parse error\n(site structure changed)
  olx_scraper --> orchestrator: ERROR
  orchestrator -> orchestrator: Log error\nNotify admins
  orchestrator --> api_router: {status: "error", message: "Cannot scrape OLX"}
  api_router --> frontend: 500 Scraping Error
  frontend --> user: Display error\n"Cannot reach OLX"\n[Retry]
end

@enduml
