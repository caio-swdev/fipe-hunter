@startuml

left to right direction

actor AlertingOrchestrator as orchestrator
actor TelegramUser as user

rectangle "Telegram Alerts System" {
  orchestrator --> (Queue Alert Message)
  user -.->|reply| (Handle User Interaction)

  (Queue Alert Message) --> (Format Alert)
  (Format Alert) --> (Process Alert Queue)
  (Process Alert Queue) --> (Send Message)

  (Send Message) --> (Validate Response)
  (Validate Response) --> (Record Alert History)

  (Send Message) ..> (Handle Rate Limit) : <<extend>>
  (Send Message) ..> (Retry on Failure) : <<extend>>

  (Retry on Failure) --> (Exponential Backoff)
  (Exponential Backoff) --> (Retry Send)

  (Handle User Interaction) ..> (Update Preferences) : <<include>>
}

note right of (Format Alert)
  Include: vehicle summary,
  discount %, score, link
end note

note right of (Process Alert Queue)
  Rate limit: 30 msg/sec
  Respect Telegram API limits
end note

@enduml
