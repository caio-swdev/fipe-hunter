@startuml

participant User
participant DashboardUI as "Dashboard\nUI"
participant StateManager
participant APIClient
participant AuthService
participant Backend as "Backend API"
database Cache

' === DASHBOARD INITIALIZATION ===

User -> DashboardUI: Access dashboard URL
activate DashboardUI

DashboardUI -> AuthService: check_session()
activate AuthService
alt Session Valid
  AuthService -> DashboardUI: return user_token
else Session Invalid
  AuthService -> User: redirect_to_login()
  deactivate AuthService
  DashboardUI --> User: (stop)
  deactivate DashboardUI
end
deactivate AuthService

DashboardUI -> DashboardUI: render_layout_shell()
DashboardUI -> StateManager: initialize_state()
activate StateManager
StateManager --> DashboardUI: initial_state
deactivate StateManager

DashboardUI -> User: display_loading_skeleton()

' === LOAD DASHBOARD METRICS ===

DashboardUI -> APIClient: GET /api/opportunities/summary
activate APIClient

APIClient -> Cache: check_cache('opportunities_summary')
alt Cache Hit (< 5min)
  Cache --> APIClient: cached_data
  APIClient --> DashboardUI: summary_metrics
else Cache Miss
  APIClient -> Backend: GET /api/opportunities/summary
  activate Backend
  Backend -> Backend: query_opportunities()
  Backend -> Backend: aggregate_metrics()
  Backend --> APIClient: {total_found: 342, new_today: 18, high_score: 45, top_score: 92}
  deactivate Backend
  APIClient -> Cache: set_cache('opportunities_summary', data, ttl=5min)
  APIClient --> DashboardUI: summary_metrics
end
deactivate APIClient

DashboardUI -> StateManager: set_metrics(summary_metrics)
DashboardUI -> DashboardUI: render_overview_section()

' === LOAD BEST DEALS ===

DashboardUI -> APIClient: GET /api/opportunities/top?limit=5
activate APIClient
APIClient -> Cache: check_cache('top_opportunities')
alt Cache Hit
  Cache --> APIClient: cached_data
else Cache Miss
  APIClient -> Backend: GET /api/opportunities/top?limit=5&sort=score_desc
  activate Backend
  Backend -> Backend: query_opportunities()
  Backend -> Backend: apply_sort(score_desc)
  Backend -> Backend: limit_results(5)
  Backend --> APIClient: [Opportunity, Opportunity, ...]
  deactivate Backend
  APIClient -> Cache: set_cache('top_opportunities', data, ttl=5min)
end
APIClient --> DashboardUI: top_deals
deactivate APIClient

DashboardUI -> StateManager: set_top_deals(top_deals)
DashboardUI -> DashboardUI: render_best_deals_widget()

' === LOAD PRICE TRENDS ===

DashboardUI -> APIClient: GET /api/opportunities/trends?days=30
activate APIClient
APIClient -> Backend: GET /api/opportunities/trends?days=30
activate Backend
Backend -> Backend: query_price_trends(days=30)
Backend -> Backend: aggregate_daily_averages()
Backend --> APIClient: [
  {date: "2024-01-15", avg_discount: 28.5},
  {date: "2024-01-16", avg_discount: 29.2},
  ...
]
deactivate Backend
APIClient -> Cache: set_cache('price_trends', data, ttl=1hour)
APIClient --> DashboardUI: trend_data
deactivate APIClient

DashboardUI -> DashboardUI: prepare_chart_data(trend_data)
DashboardUI -> DashboardUI: render_line_chart()
DashboardUI --> User: dashboard_loaded_with_data

' === USER APPLIES FILTERS ===

User -> DashboardUI: navigate_to_opportunity_browser()
activate DashboardUI

DashboardUI -> DashboardUI: render_browser_page()
DashboardUI -> APIClient: GET /api/opportunities?page=1&limit=25&sort=score_desc
activate APIClient
APIClient -> Backend: GET /api/opportunities?page=1&limit=25&sort=score_desc
activate Backend
Backend -> Backend: query_opportunities()
Backend -> Backend: apply_sort(score_desc)
Backend -> Backend: apply_pagination(page=1, limit=25)
Backend --> APIClient: {items: [...], total: 342, has_more: true}
deactivate Backend
APIClient --> DashboardUI: opportunities_page_1
deactivate APIClient

DashboardUI -> DashboardUI: render_table(opportunities_page_1)

User -> DashboardUI: set_filter(score_min=75, score_max=100, marketplaces=[olx, webmotors])
DashboardUI -> StateManager: update_filters({score_min: 75, score_max: 100, marketplaces: [olx, webmotors]})
StateManager --> DashboardUI: filters_updated

DashboardUI -> DashboardUI: show_loading_indicator()
DashboardUI -> APIClient: GET /api/opportunities/filter?score_min=75&score_max=100&marketplaces=olx,webmotors&page=1&limit=25
activate APIClient
APIClient -> Backend: GET /api/opportunities/filter?score_min=75&score_max=100&marketplaces=olx,webmotors&page=1&limit=25
activate Backend
Backend -> Backend: query_opportunities()
Backend -> Backend: apply_filter(score >= 75 AND score <= 100)
Backend -> Backend: apply_filter(marketplace IN [olx, webmotors])
Backend -> Backend: apply_sort(score_desc)
Backend -> Backend: apply_pagination()
Backend --> APIClient: {items: [...], total: 45, has_more: false}
deactivate Backend
APIClient --> DashboardUI: filtered_results
deactivate APIClient

DashboardUI -> StateManager: update_filtered_results(filtered_results)
DashboardUI -> DashboardUI: render_table(filtered_results)
DashboardUI -> DashboardUI: display_filter_status("45 results found")

' === USER VIEWS OPPORTUNITY DETAILS ===

User -> DashboardUI: click_opportunity_row(opportunity_id)
DashboardUI -> DashboardUI: show_detail_modal()

DashboardUI -> APIClient: GET /api/opportunities/{id}
activate APIClient
APIClient -> Cache: check_cache('opportunity_{id}')
alt Cache Hit
  Cache --> APIClient: detailed_opp
else Cache Miss
  APIClient -> Backend: GET /api/opportunities/{id}
  activate Backend
  Backend -> Backend: find_opportunity_by_id(id)
  Backend -> Backend: enrich_with_related_data()
  Backend --> APIClient: {
    vehicle: {...},
    listing_price: 25000,
    fipe_price: 30000,
    discount_pct: 16.7,
    score: 92,
    score_breakdown: {...},
    status: "new",
    marketplace: "OLX",
    url: "https://..."
  }
  deactivate Backend
  APIClient -> Cache: set_cache('opportunity_{id}', data, ttl=10min)
end
APIClient --> DashboardUI: opportunity_detail
deactivate APIClient

DashboardUI -> DashboardUI: render_detail_panel(opportunity_detail)
User -> User: view_opportunity_details()

User -> DashboardUI: click_open_listing_button()
DashboardUI -> User: window.open(listing_url)

' === USER EXPORTS DATA ===

User -> DashboardUI: click_export_button()
DashboardUI -> DashboardUI: show_export_dialog()

User -> DashboardUI: select_format(csv)
DashboardUI -> DashboardUI: disable_export_button()
DashboardUI -> APIClient: POST /api/opportunities/export?format=csv
activate APIClient
APIClient -> Backend: POST /api/opportunities/export?format=csv
activate Backend
Backend -> Backend: apply_current_filters()
Backend -> Backend: format_as_csv()
Backend -> Backend: generate_file()
Backend --> APIClient: CSV_BLOB
deactivate Backend
APIClient --> DashboardUI: CSV_BLOB
deactivate APIClient

DashboardUI -> DashboardUI: trigger_download()
DashboardUI -> User: download_file('opportunities-2024-01-15.csv')

' === ADMIN CONFIGURES SETTINGS ===

User -> DashboardUI: navigate_to_settings()
activate DashboardUI

DashboardUI -> APIClient: GET /api/config/all
activate APIClient
APIClient -> Cache: check_cache('config_all')
APIClient -> Backend: GET /api/config/all
activate Backend
Backend -> Backend: retrieve_config()
Backend --> APIClient: {
  scraping_schedule: {frequency: "hourly", sources: [olx, webmotors]},
  alert_thresholds: {telegram: 75, carwizard: 80},
  discount_filters: {min: 20, max: 50}
}
deactivate Backend
APIClient --> DashboardUI: current_config
deactivate APIClient

DashboardUI -> DashboardUI: populate_form_fields(current_config)

User -> DashboardUI: update_config({scraping_schedule: {frequency: "daily"}})
DashboardUI -> StateManager: set_form_values(updated_config)

User -> DashboardUI: click_save_settings()
DashboardUI -> DashboardUI: validate_form()
alt Validation Error
  DashboardUI -> User: show_validation_error()
  deactivate DashboardUI
  User --> User: (fix and retry)
else Validation Success
  DashboardUI -> APIClient: POST /api/config/update
  activate APIClient
  APIClient -> Backend: POST /api/config/update {scraping_schedule: {frequency: "daily"}}
  activate Backend
  Backend -> Backend: validate_config()
  Backend -> Backend: persist_config()
  Backend --> APIClient: {success: true, message: "Config updated"}
  deactivate Backend
  APIClient --> DashboardUI: success_response
  deactivate APIClient
  DashboardUI -> User: show_notification("Settings saved successfully")
end

' === ADMIN VIEWS MONITORING ===

User -> DashboardUI: navigate_to_monitoring()
activate DashboardUI

DashboardUI -> APIClient: GET /api/monitoring/status
activate APIClient
APIClient -> Backend: GET /api/monitoring/status
activate Backend
Backend -> Backend: get_last_scrape_time()
Backend -> Backend: get_next_scrape_time()
Backend -> Backend: calculate_success_rate()
Backend -> Backend: check_queue_status()
Backend --> APIClient: {
  last_scrape: "2024-01-15 10:00:00",
  next_scrape: "2024-01-15 11:00:00",
  success_rate: 95,
  queue_pending: 12,
  api_health: "healthy"
}
deactivate Backend
APIClient --> DashboardUI: monitoring_status
deactivate APIClient

DashboardUI -> StateManager: set_monitoring_status(monitoring_status)
DashboardUI -> DashboardUI: render_status_cards()

' === AUTO-REFRESH LOOP ===

DashboardUI -> DashboardUI: schedule_auto_refresh(interval=5min)

loop Every 5 minutes
  DashboardUI -> APIClient: GET /api/opportunities/summary
  activate APIClient
  APIClient -> Backend: GET /api/opportunities/summary
  activate Backend
  Backend --> APIClient: updated_metrics
  deactivate Backend
  APIClient --> DashboardUI: updated_metrics
  deactivate APIClient

  DashboardUI -> StateManager: update_metrics(updated_metrics)
  DashboardUI -> DashboardUI: refresh_dashboard_sections()
  DashboardUI -> User: auto_refresh_complete()
end

deactivate DashboardUI

' === ERROR HANDLING ===

note over APIClient
  Error Handling:
  - HTTP 5xx: Display "Service unavailable", show cached data
  - Timeout: Retry with backoff, max 3 attempts
  - 401 Unauthorized: Redirect to login
  - Network error: Show offline message, queue for retry
end note

note over DashboardUI
  UI Behaviors:
  - Show loading skeleton while fetching
  - Debounce filter/search (300ms)
  - Cache API responses locally
  - Auto-refresh metrics every 5 min
  - Auto-refresh monitoring every 30s
  - Handle empty states gracefully
end note

@enduml
