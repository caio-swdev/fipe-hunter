@startuml

left to right direction

actor ScoringEngine as engine

rectangle "Opportunity Scoring System" {
  engine --> (Calculate Score Components)

  (Calculate Score Components) --> (Normalize Discount Score)
  (Calculate Score Components) --> (Normalize Condition Score)
  (Calculate Score Components) --> (Estimate Demand Score)
  (Calculate Score Components) --> (Normalize Recency Score)

  (Normalize Discount Score) --> (Apply Weights)
  (Normalize Condition Score) --> (Apply Weights)
  (Estimate Demand Score) --> (Apply Weights)
  (Normalize Recency Score) --> (Apply Weights)

  (Apply Weights) --> (Calculate Final Score)
  (Calculate Final Score) --> (Rank Opportunities)

  (Rank Opportunities) --> (Flag High Scores)
  (Flag High Scores) --> (Trigger Alerts)
}

note right of (Apply Weights)
  Weights:
  - Discount: 40%
  - Condition: 30%
  - Demand: 20%
  - Recency: 10%
end note

note right of (Calculate Final Score)
  Final Score = weighted average
  Range: 0-100
end note

@enduml
