@startuml

participant OpportunityPipeline
participant ScoringService
participant DemandDataStore
participant Database

OpportunityPipeline -> ScoringService: score_opportunity(opportunity)
activate ScoringService

ScoringService -> ScoringService: extract_data()
return listing_data, discount_pct, condition, mileage, created_at

ScoringService -> ScoringService: calculate_discount_score()
note over ScoringService
  discount_pct=30% → score=60
  (linear: 20%→40, 50%→100)
end note
return discount_score=60

ScoringService -> ScoringService: calculate_condition_score()
note over ScoringService
  condition="Good" → 75
  mileage=80000 km → reduce by 5%
  final condition_score = 75 - (5% of 75) ≈ 71
end note
return condition_score=71

ScoringService -> DemandDataStore: get_demand_score(brand, model)
activate DemandDataStore
DemandDataStore --> ScoringService: demand_score=85
deactivate DemandDataStore
note over ScoringService
  Volkswagen Gol = high demand
end note

ScoringService -> ScoringService: calculate_recency_score()
note over ScoringService
  created_at = 1 day ago
  recency_score = 90
end note
return recency_score=90

ScoringService -> ScoringService: apply_weights()
note over ScoringService
  final_score = (60×0.40) + (71×0.30) + (85×0.20) + (90×0.10)
             = 24 + 21.3 + 17 + 9
             = 71.3
             ≈ 71 (rounded)
end note
return final_score=71

ScoringService -> Database: UPDATE opportunities SET score=71
Database --> ScoringService: ok

ScoringService --> OpportunityPipeline: {id: 123, score: 71, status: 'scored'}

OpportunityPipeline -> OpportunityPipeline: rank_opportunities()
note over OpportunityPipeline
  Sort by score descending
  Identify for alerts if score >= 75
end note

deactivate ScoringService

@enduml
