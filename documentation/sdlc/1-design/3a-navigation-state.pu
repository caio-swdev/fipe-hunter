@startuml
title FIPE Hunter - App Navigation State Diagram

skinparam state {
  BackgroundColor LightBlue
  BorderColor DarkBlue
  BackgroundColor<<admin>> LightYellow
  BorderColor<<admin>> Orange
  BackgroundColor<<modal>> LightGreen
  BorderColor<<modal>> DarkGreen
}

' === PAGES ===

state "Painel (Dashboard Home)" as home {
  home : Metrics Overview (total, new today, high-score, top score)
  home : Best Deals Widget (top 5 by score)
  home : Price Trends Chart (30-day discount evolution)
  home : Auto-refresh every 5 minutes
}

state "Oportunidades (Opportunity Browser)" as opportunities {
  opportunities : On-Demand Search Form (brand + model + year)
  opportunities : Search Loading Indicator (FIPE -> OLX -> Processing)
  opportunities : Filter Panel (score range, marketplace, discount range)
  opportunities : Paginated Table (25 rows/page, sortable columns)
  opportunities : Export Button (CSV, Excel, PDF)
}

state "Favoritos (Favorites)" as favorites {
  favorites : Saved / Favorited Opportunities List
  favorites : Filter and Sort Controls
  favorites : Remove Favorite Action
}

state "Analises (Analytics)" as analytics {
  analytics : Discount Distribution Histogram
  analytics : Market Trends Multi-Line Chart (30-day)
  analytics : Top Brands Bar Chart (top 10)
  analytics : Marketplace Comparison Table
  analytics : Export Analytics (CSV)
}

state "Historico (Historical)" as historical {
  historical : Archived and Purchased Opportunities List
  historical : Price Evolution Chart (90-day per vehicle)
  historical : Export Historical Data (CSV, Excel, PDF)
}

state "Configuracoes (Settings)" as settings <<admin>> {
  settings : Scraping Schedule (frequency, enabled sources, time)
  settings : Alert Thresholds (Telegram >= 75, CarWizard >= 80)
  settings : Marketplace Toggles (OLX, WebMotors)
  settings : Discount Filters (min 20%, max 50%)
  settings : Save Changes + Test Scrape Buttons
}

state "Monitoramento (Monitoring)" as monitoring <<admin>> {
  monitoring : System Health Metrics (last/next scrape, success rate)
  monitoring : Scrape Log Detail (found, saved, duplicates, errors)
  monitoring : API Health Cards (FIPE, Telegram, Sheets, CarWizard)
  monitoring : Message Queue Status (pending, failed, retry)
  monitoring : Auto-refresh every 30 seconds
}

state "Opportunity Detail (Modal)" as detail <<modal>> {
  detail : Vehicle Specifications (brand, model, year, transmission, fuel)
  detail : Price Breakdown (listing price, FIPE price, discount %, amount)
  detail : Score Breakdown (component scores + weights)
  detail : Marketplace Link (Open Listing)
  detail : Actions (Mark Purchased, Archive, Add to Favorites)
  detail : CarWizard Sync Status
}

state "On-Demand Search (Active)" as searching <<modal>> {
  searching : Progress Steps (FIPE Lookup -> OLX Scraping -> Processing)
  searching : Estimated Time Remaining
  searching : Cancel Search Button
}

state "Empty State (No Data)" as empty {
  empty : No opportunities found yet
  empty : Trigger Manual Scrape CTA
}

' === ENTRY POINT ===
[*] --> home : User authenticated

' === GLOBAL NAV FROM HOME ===
home --> opportunities : Click Oportunidades
home --> favorites : Click Favoritos
home --> analytics : Click Analises
home --> historical : Click Historico
home --> settings : Click Settings (Admin only)
home --> monitoring : Click Monitoring (Admin only)
home --> detail : Click Best Deal item

' === GLOBAL NAV FROM OPPORTUNITIES ===
opportunities --> home : Click Painel
opportunities --> favorites : Click Favoritos
opportunities --> analytics : Click Analises
opportunities --> historical : Click Historico
opportunities --> detail : Click table row

' === GLOBAL NAV FROM FAVORITES ===
favorites --> home : Click Painel
favorites --> opportunities : Click Oportunidades
favorites --> analytics : Click Analises
favorites --> detail : Click favorited item

' === GLOBAL NAV FROM ANALYTICS ===
analytics --> home : Click Painel
analytics --> opportunities : Click Oportunidades
analytics --> favorites : Click Favoritos

' === GLOBAL NAV FROM HISTORICAL ===
historical --> home : Click Painel
historical --> opportunities : Click Oportunidades
historical --> analytics : Click Analises
historical --> detail : Click archived item

' === ADMIN PAGE NAVIGATION ===
settings --> home : Click Painel
settings --> monitoring : Click Monitoring
settings --> opportunities : Click Oportunidades

monitoring --> home : Click Painel
monitoring --> settings : Click Settings
monitoring --> opportunities : Click Oportunidades

' === DETAIL MODAL CLOSE ===
detail --> opportunities : Close modal (from Oportunidades)
detail --> favorites : Close modal (from Favoritos)
detail --> historical : Close modal (from Historico)
detail --> home : Close modal (from Home)

' === ON-DEMAND SEARCH FLOW ===
opportunities --> searching : Click Buscar (Search Now)
searching --> opportunities : Search complete (results in table)
searching --> opportunities : User clicks Cancel Search

' === EMPTY STATE FLOW ===
home --> empty : No data on first run
empty --> monitoring : Click Scrape Now

' === EXIT ===
home --> [*] : Logout
opportunities --> [*] : Session timeout (30 min inactivity)
settings --> [*] : Logout

note right of home
  Landing Page
  First page after login.
  Auto-refreshes metrics every 5 min.
end note

note right of settings
  Admin Only
  Requires elevated permissions.
end note

note right of detail
  Modal / Slide-over Panel
  Opens over current page.
  Does not change URL route.
end note

note right of searching
  Active Search State
  Overlays Opportunity Browser.
  Progress: FIPE -> OLX -> Scoring.
  Cross-feature: UC32 includes UC4, UC6, UC8-9
  (Ref: 12-usecase-dependency.pu)
end note

@enduml
