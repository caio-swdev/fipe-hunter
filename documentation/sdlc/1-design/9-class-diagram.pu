@startuml

' === MODELS / DOMAIN ENTITIES ===

class Vehicle {
  - id: UUID
  - brand: string
  - model: string
  - year: int
  - version: string
  - transmission: string
  - fuel_type: string
  --
  + __init__(brand, model, year, version, transmission, fuel_type)
  + get_fipe_key(): string
  + validate(): bool
  + to_dict(): dict
}

class Listing {
  - id: UUID
  - vehicle_id: UUID
  - marketplace: str
  - listing_price: float
  - currency: str
  - mileage: int
  - condition: str
  - url: string
  - description: string
  - seller_name: string
  - seller_rating: float
  - created_at: datetime
  - scraped_at: datetime
  - is_duplicate: bool
  --
  + __init__(vehicle, marketplace, price, mileage, condition, url)
  + validate(): bool
  + is_expired(): bool
  + to_dict(): dict
}

class Opportunity {
  - id: UUID
  - listing_id: UUID
  - fipe_price: float
  - discount_pct: float
  - discount_amount: float
  - score: int
  - status: str
  - carwizard_id: string
  - created_at: datetime
  - updated_at: datetime
  --
  + __init__(listing, fipe_price)
  + set_discount(fipe_price): void
  + calculate_score(): int
  + update_status(status): void
  + to_dict(): dict
}

class Alert {
  - id: UUID
  - opportunity_id: UUID
  - channel: str
  - recipient: str
  - status: str
  - message: string
  - sent_at: datetime
  - error_message: string
  - retry_count: int
  --
  + __init__(opportunity, channel, recipient)
  + format_message(): string
  + mark_sent(): void
  + mark_failed(error): void
  + should_retry(): bool
}

class PriceCache {
  - id: UUID
  - vehicle_key: string
  - fipe_price: float
  - cached_at: datetime
  - expires_at: datetime
  --
  + __init__(vehicle_key, price)
  + is_expired(): bool
  + to_price(): float
}

class AlertHistory {
  - id: UUID
  - opportunity_id: UUID
  - alert_id: UUID
  - channel: str
  - status: str
  - timestamp: datetime
  --
  + __init__(opportunity_id, alert_id, channel, status)
  + record(): void
}

' === DTOs ===

class ListingDTO {
  - brand: string
  - model: string
  - year: int
  - price: float
  - mileage: int
  - condition: string
  - url: string
  - description: string
  --
  + from_dict(data): ListingDTO
  + to_listing(): Listing
  + validate(): bool
}

class OpportunityDTO {
  - listing_id: UUID
  - vehicle_id: UUID
  - fipe_price: float
  - discount_pct: float
  - score: int
  - status: str
  --
  + from_opportunity(opp): OpportunityDTO
  + to_dict(): dict
}

class AlertMessageDTO {
  - opportunity_id: UUID
  - vehicle_summary: string
  - discount_pct: float
  - score: int
  - url: string
  - timestamp: datetime
  --
  + from_opportunity(opp): AlertMessageDTO
  + format_telegram(): string
  + format_sheets_row(): list
}

' === VALIDATORS ===

class ListingValidator {
  --
  + validate_brand(brand): bool
  + validate_model(model): bool
  + validate_year(year): bool
  + validate_price(price): bool
  + validate_mileage(mileage): bool
  + validate_condition(condition): bool
  + validate_url(url): bool
  + validate_listing(listing): ValidationResult
}

class VehicleValidator {
  --
  + validate_for_fipe_lookup(vehicle): bool
  + normalize_brand_name(brand): string
  + normalize_model_name(model): string
}

class ScoreValidator {
  --
  + validate_score(score): bool
  + validate_discount(discount): bool
  + validate_in_range(score, min, max): bool
}

' === REPOSITORIES ===

class ListingRepository {
  - db_session: Session
  --
  + save(listing: Listing): UUID
  + find_by_id(id: UUID): Listing
  + find_by_url(url: string): Listing
  + find_by_marketplace(marketplace: str): List<Listing>
  + find_all(limit, offset): List<Listing>
  + find_duplicates(listing: Listing): List<Listing>
  + update(listing: Listing): void
  + delete(id: UUID): void
  + count(): int
}

class OpportunityRepository {
  - db_session: Session
  --
  + save(opportunity: Opportunity): UUID
  + find_by_id(id: UUID): Opportunity
  + find_all(limit, offset): List<Opportunity>
  + find_by_score(min_score: int): List<Opportunity>
  + find_by_status(status: str): List<Opportunity>
  + find_by_carwizard_id(cw_id: string): Opportunity
  + update(opportunity: Opportunity): void
  + delete(id: UUID): void
  + count(): int
}

class AlertRepository {
  - db_session: Session
  --
  + save(alert: Alert): UUID
  + find_by_id(id: UUID): Alert
  + find_by_opportunity(opp_id: UUID): List<Alert>
  + find_by_status(status: str): List<Alert>
  + find_failed_alerts(): List<Alert>
  + update(alert: Alert): void
  + record_history(history: AlertHistory): void
  + count_sent_today(): int
}

class PriceCacheRepository {
  - redis_client: RedisClient
  --
  + get(vehicle_key: string): PriceCache
  + set(vehicle_key: string, price: float, ttl: int): void
  + delete(vehicle_key: string): void
  + exists(vehicle_key: string): bool
  + clear_expired(): int
}

' === EXTERNAL API CLIENTS ===

class OLXScraperClient {
  - session: RequestSession
  - user_agents: List<str>
  - request_delay: int
  --
  + scrape_listings(): List<Listing>
  - get_page_html(): string
  - parse_listing_element(element): Listing
  - rotate_user_agent(): string
  - apply_delay(): void
  - handle_blocked_request(): Listing
}

class WebMotorsScraperClient {
  - session: RequestSession
  - user_agents: List<str>
  - request_delay: int
  --
  + scrape_listings(): List<Listing>
  - get_page_html(): string
  - parse_listing_element(element): Listing
  - rotate_user_agent(): string
  - apply_delay(): void
  - handle_blocked_request(): Listing
}

class FIPEAPIClient {
  - api_url: string
  - timeout: int
  --
  + get_brands(): List<str>
  + get_models(brand: str): List<str>
  + get_years(brand: str, model: str): List<int>
  + get_price(brand: str, model: str, year: int): float
  - build_request_url(brand, model, year): string
  - parse_response(response): float
  - handle_not_found(): float
  - handle_rate_limit(): void
}

class GoogleSheetsClient {
  - service: GoogleSheetsService
  - spreadsheet_id: string
  --
  + append_values(sheet_name, values): void
  + get_values(sheet_name, range): List
  - build_append_request(values): dict
  - handle_quota_exceeded(): void
  - retry_with_backoff(operation, max_retries): void
}

class TelegramAPIClient {
  - bot_token: string
  - api_url: string
  --
  + send_message(chat_id: str, text: str): bool
  + validate_token(): bool
  + get_me(): dict
  - build_request_url(endpoint): string
  - parse_response(response): dict
  - handle_rate_limit(): void
}

class CarWizardAPIClient {
  - api_url: string
  - api_key: string
  --
  + send_opportunity(payload: dict): string
  + get_opportunity_status(cw_id: string): string
  + get_vehicle_history(vehicle: Vehicle): dict
  - build_auth_header(): dict
  - build_payload(opportunity): dict
  - handle_api_error(error): void
}

' === USE CASES / ORCHESTRATORS ===

class ScrapingOrchestrator {
  - olx_scraper: OLXScraperClient
  - webmotors_scraper: WebMotorsScraperClient
  - listing_repo: ListingRepository
  - validator: ListingValidator
  --
  + scrape_all_marketplaces(): List<Listing>
  + scrape_marketplace(marketplace: str): List<Listing>
  - deduplicate_listings(listings: List<Listing>): List<Listing>
  - validate_and_save(listings: List<Listing>): List<Listing>
}

class PriceComparisonOrchestrator {
  - fipe_client: FIPEAPIClient
  - cache_repo: PriceCacheRepository
  - vehicle_validator: VehicleValidator
  --
  + get_fipe_price(vehicle: Vehicle): float
  - try_cache(vehicle: Vehicle): float
  - lookup_fipe(vehicle: Vehicle): float
  - cache_result(vehicle: Vehicle, price: float): void
  - handle_lookup_failure(vehicle: Vehicle): float
}

class ScoringOrchestrator {
  - discount_weight: float = 0.40
  - condition_weight: float = 0.30
  - demand_weight: float = 0.20
  - recency_weight: float = 0.10
  --
  + score_opportunity(listing: Listing, fipe_price: float): int
  - normalize_discount_score(discount_pct: float): int
  - normalize_condition_score(condition: str): int
  - estimate_demand_score(brand: str, model: str): int
  - normalize_recency_score(created_at: datetime): int
  - apply_weights(components: dict): int
}

class OpportunityPipeline {
  - scraper: ScrapingOrchestrator
  - price_comp: PriceComparisonOrchestrator
  - scorer: ScoringOrchestrator
  - opportunity_repo: OpportunityRepository
  --
  + process_listings(listings: List<Listing>): List<Opportunity>
  - create_opportunity(listing: Listing, fipe_price: float): Opportunity
  - should_alert(opportunity: Opportunity): bool
}

class AlertingOrchestrator {
  - telegram_client: TelegramAPIClient
  - sheets_client: GoogleSheetsClient
  - alert_repo: AlertRepository
  --
  + send_alerts(opportunity: Opportunity, recipients: List<str>): void
  + log_to_sheets(opportunity: Opportunity): void
  - format_telegram_message(opportunity: Opportunity): str
  - queue_alerts(alerts: List<Alert>): void
  - process_alert_queue(): void
}

class CarWizardSyncOrchestrator {
  - carwizard_client: CarWizardAPIClient
  - opportunity_repo: OpportunityRepository
  --
  + sync_qualified_opportunities(): int
  + sync_opportunity(opportunity: Opportunity): string
  + update_opportunity_status(cw_id: str, status: str): void
  - should_sync(opportunity: Opportunity): bool
  - handle_sync_failure(opportunity: Opportunity, error: str): void
}

class OnDemandSearchOrchestrator {
  - query_validator: SearchQueryValidator
  - query_parser: SearchQueryParser
  - fipe_client: FIPEAPIClient
  - cache_repo: PriceCacheRepository
  - olx_scraper: OLXScraperClient
  - listing_validator: ListingValidator
  - listing_repo: ListingRepository
  - price_comp_orchestra: PriceComparisonOrchestrator
  - scoring_orchestra: ScoringOrchestrator
  - opportunity_repo: OpportunityRepository
  - sheets_client: GoogleSheetsClient
  - telegram_client: TelegramAPIClient
  - carwizard_client: CarWizardAPIClient
  --
  + execute(brand: str, model: str, year: int): List<Opportunity>
  - parse_query(brand, model, year): SearchQuery
  - lookup_fipe_price(vehicle: Vehicle): float
  - scrape_olx_listings(search_query: str): List<Listing>
  - deduplicate_listings(listings: List<Listing>): List<Listing>
  - compare_prices(listings, fipe_price): List<Listing>
  - score_opportunities(listings): List<Opportunity>
  - persist_opportunities(opportunities): void
  - log_to_sheets(opportunities): void
  - send_alerts(opportunities): void
  - sync_carwizard(opportunities): void
  - handle_error(error: Exception): void
}

class SearchQuery {
  - brand: str
  - model: str
  - year: int (optional)
  --
  + normalize(): void
  + to_fipe_query(): str
  + to_olx_search_url(): str
}

class SearchQueryValidator {
  --
  + validate(brand, model, year): ValidationResult
  + validate_brand(brand): bool
  + validate_model(model): bool
  + validate_year(year): bool
}

class SearchQueryParser {
  --
  + parse(brand: str, model: str, year: int): SearchQuery
  + normalize_brand(brand: str): str
  + normalize_model(model: str): str
  + get_brand_variations(brand: str): List<str>
}

' === RELATIONSHIPS ===

Listing --> Vehicle
Opportunity --> Listing
Alert --> Opportunity
PriceCache --> Vehicle
AlertHistory --> Opportunity
AlertHistory --> Alert

ListingDTO --> Vehicle
OpportunityDTO --> Listing
AlertMessageDTO --> Opportunity

ListingValidator --> Listing
VehicleValidator --> Vehicle
ScoreValidator --> Opportunity

ListingRepository --> Listing
OpportunityRepository --> Opportunity
AlertRepository --> Alert
PriceCacheRepository --> PriceCache

ScrapingOrchestrator --> OLXScraperClient
ScrapingOrchestrator --> WebMotorsScraperClient
ScrapingOrchestrator --> ListingValidator
ScrapingOrchestrator --> ListingRepository

PriceComparisonOrchestrator --> FIPEAPIClient
PriceComparisonOrchestrator --> PriceCacheRepository
PriceComparisonOrchestrator --> VehicleValidator

ScoringOrchestrator --> Opportunity

OpportunityPipeline --> ScrapingOrchestrator
OpportunityPipeline --> PriceComparisonOrchestrator
OpportunityPipeline --> ScoringOrchestrator
OpportunityPipeline --> OpportunityRepository

AlertingOrchestrator --> TelegramAPIClient
AlertingOrchestrator --> GoogleSheetsClient
AlertingOrchestrator --> AlertRepository

CarWizardSyncOrchestrator --> CarWizardAPIClient
CarWizardSyncOrchestrator --> OpportunityRepository

OnDemandSearchOrchestrator --> SearchQueryValidator
OnDemandSearchOrchestrator --> SearchQueryParser
OnDemandSearchOrchestrator --> FIPEAPIClient
OnDemandSearchOrchestrator --> PriceCacheRepository
OnDemandSearchOrchestrator --> OLXScraperClient
OnDemandSearchOrchestrator --> ListingValidator
OnDemandSearchOrchestrator --> ListingRepository
OnDemandSearchOrchestrator --> PriceComparisonOrchestrator
OnDemandSearchOrchestrator --> ScoringOrchestrator
OnDemandSearchOrchestrator --> OpportunityRepository
OnDemandSearchOrchestrator --> GoogleSheetsClient
OnDemandSearchOrchestrator --> TelegramAPIClient
OnDemandSearchOrchestrator --> CarWizardAPIClient

SearchQueryValidator --> SearchQuery
SearchQueryParser --> SearchQuery

@enduml
