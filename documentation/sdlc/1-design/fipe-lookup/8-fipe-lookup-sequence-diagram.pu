@startuml

participant PriceComparisonEngine
participant FIPELookupService
participant CacheRepository
participant FIPEAPIClient
database FIPEDatabase

PriceComparisonEngine -> FIPELookupService: get_price(vehicle: Volkswagen Gol 2015)
activate FIPELookupService

FIPELookupService -> FIPELookupService: normalize_vehicle_data()
return normalized: {brand: "Volkswagen", model: "Gol", year: 2015}

FIPELookupService -> FIPELookupService: generate_cache_key()
return cache_key: "volkswagen-gol-2015"

FIPELookupService -> CacheRepository: get(cache_key)
activate CacheRepository

CacheRepository -> CacheRepository: check_expiration()
alt Cache Hit & Not Expired
  CacheRepository --> FIPELookupService: {price: 25000.00, cached_at: ..., expires_at: ...}
  deactivate CacheRepository

  FIPELookupService --> PriceComparisonEngine: 25000.00
  note over FIPELookupService
    Cache Hit: Return in < 100ms
    No API call made
  end note

else Cache Miss or Expired
  CacheRepository --> FIPELookupService: null
  deactivate CacheRepository

  FIPELookupService -> FIPEAPIClient: query_brands()
  activate FIPEAPIClient

  FIPEAPIClient -> FIPEDatabase: GET /marcas
  FIPEDatabase --> FIPEAPIClient: [{id: 23, name: "Volkswagen"}, ...]

  FIPEAPIClient -> FIPEAPIClient: fuzzy_match_brand(search: "Volkswagen", brands)
  return brand_id: 23

  FIPEAPIClient --> FIPELookupService: brand_id: 23
  deactivate FIPEAPIClient

  FIPELookupService -> FIPEAPIClient: query_models(brand_id: 23)
  activate FIPEAPIClient

  FIPEAPIClient -> FIPEDatabase: GET /marcas/23/modelos
  FIPEDatabase --> FIPEAPIClient: [{id: 2, name: "Gol"}, ...]

  FIPEAPIClient -> FIPEAPIClient: fuzzy_match_model(search: "Gol", models)
  return model_id: 2

  FIPEAPIClient --> FIPELookupService: model_id: 2
  deactivate FIPEAPIClient

  FIPELookupService -> FIPEAPIClient: query_years(brand_id: 23, model_id: 2)
  activate FIPEAPIClient

  FIPEAPIClient -> FIPEDatabase: GET /marcas/23/modelos/2/anos
  FIPEDatabase --> FIPEAPIClient: [{year: "2015-1", label: "2015 Gen 1"}, ...]

  FIPEAPIClient -> FIPEAPIClient: match_year(search: 2015, years)
  return year_key: "2015-1"

  FIPEAPIClient --> FIPELookupService: year_key: "2015-1"
  deactivate FIPEAPIClient

  FIPELookupService -> FIPEAPIClient: query_price(brand_id: 23, model_id: 2, year: "2015-1")
  activate FIPEAPIClient

  FIPEAPIClient -> FIPEDatabase: GET /marcas/23/modelos/2/anos/2015-1
  FIPEDatabase --> FIPEAPIClient: {
    "nome": "Volkswagen Gol 1.0",
    "valor": "R$ 25.000,00",
    "marca": "Volkswagen",
    "modelo": "Gol"
  }

  FIPEAPIClient -> FIPEAPIClient: parse_price(response)
  return price: 25000.00

  FIPEAPIClient --> FIPELookupService: price: 25000.00
  deactivate FIPEAPIClient

  FIPELookupService -> FIPELookupService: build_cache_entry()
  return cache_entry: {
    price: 25000.00,
    cached_at: 2024-01-15 10:30:00,
    expires_at: 2024-01-16 10:30:00,
    version: "Gol 1.0"
  }

  FIPELookupService -> CacheRepository: set(cache_key, cache_entry, ttl: 86400)
  activate CacheRepository
  CacheRepository --> FIPELookupService: ok
  deactivate CacheRepository

  FIPELookupService --> PriceComparisonEngine: 25000.00
  note over FIPELookupService
    Cache Miss: Full API query
    Result cached for 24 hours
    Response time: 1-5 seconds
  end note
end

' === ERROR HANDLING ===

alt FIPE API Timeout
  FIPEAPIClient -x FIPEDatabase: Request timeout (>10s)
  FIPEAPIClient -> FIPEAPIClient: retry_request()
  alt Retry Succeeds
    FIPEAPIClient -> FIPEDatabase: GET /marcas/23/...
    FIPEDatabase --> FIPEAPIClient: success
  else Retry Fails
    FIPEAPIClient -> FIPELookupService: return error
    FIPELookupService -> FIPELookupService: log_failure()
    FIPELookupService --> PriceComparisonEngine: null (with error logged)
  end
end

alt FIPE API Rate Limit (HTTP 429)
  FIPEAPIClient -x FIPEDatabase: HTTP 429 Too Many Requests
  FIPEAPIClient -> FIPEAPIClient: backoff_wait(60 seconds)
  FIPEAPIClient -> FIPEAPIClient: retry_request()
end

alt Vehicle Not Found
  FIPEAPIClient -x FIPEDatabase: Model not found (404)
  FIPEAPIClient -> FIPELookupService: return error
  FIPELookupService -> FIPELookupService: log_failure(vehicle, error_type)
  FIPELookupService --> PriceComparisonEngine: null (with error logged)
  note over PriceComparisonEngine
    Opportunity marked for manual review
    Pipeline continues (doesn't crash)
  end note
end

deactivate FIPELookupService

@enduml
