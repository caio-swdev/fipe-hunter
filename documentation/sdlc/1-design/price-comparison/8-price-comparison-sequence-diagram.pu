@startuml

participant ScoringEngine
participant PriceComparisonService
participant Database

ScoringEngine -> PriceComparisonService: compare_prices(listing, fipe_price)
activate PriceComparisonService

PriceComparisonService -> PriceComparisonService: validate_prices()
alt Prices Valid
  PriceComparisonService -> PriceComparisonService: calculate_discount()
  note over PriceComparisonService
    discount% = (FIPE - listing) / FIPE * 100
    e.g., (25000 - 20000) / 25000 = 0.20 = 20%
  end note

  PriceComparisonService -> PriceComparisonService: evaluate_threshold()

  alt discount < 20%
    PriceComparisonService --> ScoringEngine: {status: 'excluded', discount_pct: 15.0}
    note over PriceComparisonService
      Below threshold - not an opportunity
    end note

  else 20% <= discount <= 50%
    PriceComparisonService -> PriceComparisonService: create_opportunity()
    PriceComparisonService -> Database: INSERT opportunities
    Database --> PriceComparisonService: opportunity_id

    PriceComparisonService --> ScoringEngine: {status: 'opportunity', discount_pct: 35.0, id: 123}
    note over PriceComparisonService
      Valid opportunity - proceed to scoring
    end note

  else discount > 50%
    PriceComparisonService -> PriceComparisonService: flag_suspicious()
    PriceComparisonService -> Database: INSERT opportunities (status='suspicious')
    Database --> PriceComparisonService: opportunity_id

    PriceComparisonService --> ScoringEngine: {status: 'suspicious', discount_pct: 65.0, requires_review: true}
    note over PriceComparisonService
      Potential fraud - flag for manual review
    end note
  end

else Prices Invalid
  PriceComparisonService -> PriceComparisonService: log_validation_error()
  PriceComparisonService --> ScoringEngine: {status: 'error', message: 'Invalid price data'}
  note over PriceComparisonService
    Data quality issue - skip this comparison
  end note
end

deactivate PriceComparisonService

@enduml
