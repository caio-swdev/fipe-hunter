@startuml

left to right direction

actor ScoringEngine as scorer

rectangle "Price Comparison System" {
  scorer --> (Retrieve FIPE Price)
  scorer --> (Calculate Discount)

  (Retrieve FIPE Price) --> (Get Reference Price)
  (Get Reference Price) --> (Validate Price)

  (Calculate Discount) --> (Compare Prices)
  (Compare Prices) --> (Calculate Percentage)
  (Calculate Percentage) --> (Evaluate Threshold)

  (Evaluate Threshold) --> (Mark Opportunity?)

  (Mark Opportunity?) --> (Flag Suspicious)
  (Mark Opportunity?) --> (Create Opportunity)

  (Flag Suspicious) ..> (Flag High Discount >50%) : <<include>>
  (Create Opportunity) --> (Log Comparison)

  (Validate Price) ..> (Handle Invalid FIPE) : <<extend>>
}

note right of (Calculate Percentage)
  Formula:
  discount% = (FIPE - listing) / FIPE * 100
end note

note right of (Evaluate Threshold)
  Thresholds:
  < 20%: below threshold
  20-50%: opportunity
  > 50%: suspicious/fraud
end note

@enduml
