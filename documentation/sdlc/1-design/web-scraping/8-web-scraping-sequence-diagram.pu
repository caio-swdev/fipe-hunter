@startuml

actor Scheduler
participant ScrapingOrchestrator
participant OLXScraperClient
participant HTTPSession
participant Database
participant ScoringOrchestrator

Scheduler -> ScrapingOrchestrator: scrape_all_marketplaces()
activate ScrapingOrchestrator

ScrapingOrchestrator -> ScrapingOrchestrator: create_scrape_log('running')
ScrapingOrchestrator -> Database: insert scrape_log
Database --> ScrapingOrchestrator: log_id

' === OLX SCRAPING ===

ScrapingOrchestrator -> OLXScraperClient: scrape_listings()
activate OLXScraperClient

OLXScraperClient -> OLXScraperClient: get_random_user_agent()
return user_agent

OLXScraperClient -> HTTPSession: initialize(user_agent='Mozilla/5.0...')
activate HTTPSession

OLXScraperClient -> HTTPSession: get('https://rj.olx.com.br/...')
HTTPSession -> HTTPSession: apply_delay(1-3 seconds)
HTTPSession --> OLXScraperClient: HTML response
deactivate HTTPSession

OLXScraperClient -> OLXScraperClient: parse_html(response)
OLXScraperClient -> OLXScraperClient: extract_listings() : List<HTMLElement>

loop For each listing element (20-50 items)
  OLXScraperClient -> OLXScraperClient: parse_listing(element)
  OLXScraperClient -> OLXScraperClient: create_listing_dto()

  OLXScraperClient -> OLXScraperClient: validate_listing(dto)
  alt Validation Success
    OLXScraperClient -> OLXScraperClient: add_to_batch(listing_dto)
  else Validation Failed
    OLXScraperClient -> OLXScraperClient: log_validation_error()
  end
end

OLXScraperClient -> OLXScraperClient: save_to_database(batch)
OLXScraperClient -> Database: insert batch of listings
Database --> OLXScraperClient: saved_count = 45

OLXScraperClient -> OLXScraperClient: check_pagination()
alt More pages available
  OLXScraperClient -> HTTPSession: apply_delay(2-3 seconds)
  HTTPSession --> OLXScraperClient: next_page_response
  OLXScraperClient -> OLXScraperClient: parse_and_save_next_page()
else No more pages
  OLXScraperClient -> OLXScraperClient: deduplication_needed = false
end

return listings = [Listing, Listing, ...]
deactivate OLXScraperClient

' === DEDUPLICATION ===

ScrapingOrchestrator -> ScrapingOrchestrator: deduplicate_listings(scraped_listings)

loop For each listing
  ScrapingOrchestrator -> Database: SELECT * FROM listings WHERE url = ?
  alt URL exists
    Database --> ScrapingOrchestrator: existing_listing
    ScrapingOrchestrator -> Database: UPDATE listings SET is_duplicate = true
    ScrapingOrchestrator -> ScrapingOrchestrator: duplicate_count++
  else URL new
    ScrapingOrchestrator -> Database: INSERT INTO listings
    Database --> ScrapingOrchestrator: listing_id
    ScrapingOrchestrator -> ScrapingOrchestrator: unique_count++
  end
end

' === SCRAPE LOG UPDATE ===

ScrapingOrchestrator -> ScrapingOrchestrator: log_summary = {
  listings_found: 50,
  listings_saved: 45,
  duplicates: 5,
  status: 'completed'
}

ScrapingOrchestrator -> Database: UPDATE scrape_log SET status='completed', ...
Database --> ScrapingOrchestrator: update_ok

' === TRIGGER DOWNSTREAM ===

ScrapingOrchestrator -> ScoringOrchestrator: process_new_listings(45)
activate ScoringOrchestrator

ScoringOrchestrator -> ScoringOrchestrator: for each listing: lookup_fipe_price()
ScoringOrchestrator -> ScoringOrchestrator: for each listing: calculate_score()

return opportunities_created = 12

deactivate ScoringOrchestrator

return scrape_complete
deactivate ScrapingOrchestrator

Scheduler --> Scheduler: Await next schedule (1 hour)

' === ERROR HANDLING ===

note over HTTPSession
  Error Handling:
  - HTTP 429: Increase delay, retry
  - HTTP 5xx: Exponential backoff, 3 attempts
  - Timeout: Retry with backoff
  - Parse error: Log, skip element, continue
end note

note over OLXScraperClient
  Deduplication Strategy:
  - By URL (primary key)
  - Mark duplicates with flag
  - Keep for audit trail
  - Don't reject/delete
end note

note over ScrapingOrchestrator
  Sequence Summary:
  1. Create scrape log
  2. Scrape each marketplace
  3. Validate & save listings
  4. Deduplicate by URL
  5. Update scrape log
  6. Trigger price lookup
end note

@enduml
